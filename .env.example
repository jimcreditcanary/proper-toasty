# ─── Propertoasty environment variables ──────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# Never commit .env.local.

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase (auth, database, floorplan storage) ────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe (credits / pay-per-check) ────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Anthropic Claude (Opus 4.7 floorplan vision analysis) ───────────────────
ANTHROPIC_API_KEY=

# ─── Google Maps Platform (Places, Solar API, Static Maps) ───────────────────
# One server-only key, restricted by API + IP. Never expose to the browser.
GOOGLE_MAPS_SERVER_KEY=

# ─── EPC Register (epc.opendatacommunities.org) ──────────────────────────────
# Basic-auth encoded API key from the free developer registration.
EPC_API_KEY=

# ─── Floorplan storage ───────────────────────────────────────────────────────
# Supabase Storage bucket name (or S3/R2 bucket if swapped).
STORAGE_BUCKET=floorplans
STORAGE_SIGNING_KEY=

# ─── Finance model constants (tweakable without redeploy) ────────────────────
ENERGY_IMPORT_PRICE_P_PER_KWH=27
ENERGY_EXPORT_PRICE_P_PER_KWH=15
SOLAR_INSTALL_PRICE_PER_KWP_GBP=1100
BUS_ASHP_GRANT_GBP=7500
BUS_AIR_TO_AIR_GRANT_GBP=2500
BUS_GSHP_GRANT_GBP=7500
BUS_BIOMASS_GRANT_GBP=5000
