# ─── Propertoasty environment variables ──────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# Never commit .env.local.

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Feature flags ───────────────────────────────────────────────────────────
# Gate in-progress features. Flip to "true" when ready for demo / launch.
FEATURE_PROPERTOASTY_CHECK=false

# ─── Supabase (auth, database, floorplan storage) ────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe (credits / pay-per-check) ────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Anthropic Claude (Opus 4.7 floorplan vision analysis) ───────────────────
ANTHROPIC_API_KEY=

# ─── Google Maps Platform (Solar API + Static Maps) ──────────────────────────
# Server-only. Restrict by API + IP. Solar API must be enabled on the project.
GOOGLE_MAPS_SERVER_KEY=

# ─── Postcoder (UK address lookup with UPRN + lat/lng) ───────────────────────
# postcoder.com key — used by /api/address/lookup for Step 1.
POSTCODER_API_KEY=

# ─── EPC Register (epc.opendatacommunities.org) ──────────────────────────────
# Basic-auth encoded API key from the free developer registration.
EPC_API_KEY=

# ─── Floorplan storage ───────────────────────────────────────────────────────
# Supabase Storage bucket name (or S3/R2 bucket if swapped).
STORAGE_BUCKET=floorplans
STORAGE_SIGNING_KEY=

# ─── Octopus calculator API (savings calculator on report page) ──────────────
# Bearer token for the gcp-engineeringpipelines calculator endpoint.
# Tenant schema is hard-coded to "octopus" (header X-Tenant-Schema).
OCTOPUS_CALCULATOR_BEARER=

# ─── Finance & sizing constants (tweakable without redeploy) ─────────────────
ENERGY_IMPORT_PRICE_P_PER_KWH=27
ENERGY_EXPORT_PRICE_P_PER_KWH=15
SELF_CONSUMPTION_RATE_NO_BATTERY=0.60
SELF_CONSUMPTION_RATE_WITH_BATTERY=0.80
SOLAR_INSTALL_PRICE_PER_KWP_GBP=1100
HEAT_PUMP_DEMAND_KWH_PER_M2=60
HEAT_PUMP_W_PER_M2=50
BUS_ASHP_GRANT_GBP=7500
BUS_AIR_TO_AIR_GRANT_GBP=2500
BUS_GSHP_GRANT_GBP=7500
BUS_BIOMASS_GRANT_GBP=5000
